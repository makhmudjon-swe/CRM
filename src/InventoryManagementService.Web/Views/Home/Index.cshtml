@model DashboardDto
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon bg-primary bg-opacity-15 text-primary">
                    <i class="fas fa-building"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold text-dark">@Model.TotalCustomers</div>
                    <div class="text-muted small">Jami mijozlar</div>
                    <div class="text-success small"><i class="fas fa-arrow-up me-1"></i>@Model.NewCustomersThisMonth bu oy yangi</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon bg-warning bg-opacity-15 text-warning">
                    <i class="fas fa-handshake"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold text-dark">@Model.ActiveDeals</div>
                    <div class="text-muted small">Faol bitimlar</div>
                    <div class="text-success small"><i class="fas fa-trophy me-1"></i>@Model.DealsWonThisMonth bu oy yutildi</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon bg-success bg-opacity-15 text-success">
                    <i class="fas fa-coins"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold text-dark">@(Model.MonthlyRevenue.ToString("N0")) so'm</div>
                    <div class="text-muted small">Oylik daromad</div>
                    <div class="text-muted small">Jami: @(Model.TotalRevenue.ToString("N0")) so'm</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon bg-info bg-opacity-15 text-info">
                    <i class="fas fa-tags"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold text-dark">@Model.TotalProducts</div>
                    <div class="text-muted small">Faol mahsulotlar</div>
                    <div class="text-muted small">Katalogda</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-xl-8">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center justify-content-between py-3">
                <span><i class="fas fa-handshake text-primary me-2"></i>So'nggi bitimlar</span>
                <a asp-controller="Deals" asp-action="Index" class="btn btn-sm btn-outline-primary">Barchasi</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Bitim</th>
                            <th>Mijoz</th>
                            <th>Holat</th>
                            <th>Summa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.RecentDeals)
                        {
                            <tr>
                                <td class="ps-3">
                                    <a asp-controller="Deals" asp-action="Details" asp-route-id="@d.Id"
                                       class="text-decoration-none fw-semibold text-dark">@d.Title</a>
                                </td>
                                <td><span class="text-muted small">@d.CustomerName</span></td>
                                <td>
                                    <span class="badge bg-@(WholesaleCRM.Application.EnumHelper.GetDealStatusBadge(d.StatusValue))">
                                        @d.Status
                                    </span>
                                </td>
                                <td class="fw-semibold">@(d.TotalAmount.ToString("N0"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center justify-content-between py-3">
                <span><i class="fas fa-history text-primary me-2"></i>So'nggi faoliyatlar</span>
                <a asp-controller="Activities" asp-action="Index" class="btn btn-sm btn-outline-primary">Barchasi</a>
            </div>
            <div class="card-body" style="max-height:380px;overflow-y:auto;">
                @foreach (var a in Model.RecentActivities)
                {
                    <div class="activity-item">
                        <div class="d-flex align-items-start gap-2">
                            <i class="fas @a.TypeIcon text-primary mt-1" style="font-size:0.85rem;"></i>
                            <div class="flex-grow-1">
                                <div class="fw-semibold small">@a.Subject</div>
                                @if (!string.IsNullOrEmpty(a.CustomerName))
                                {
                                    <div class="text-muted" style="font-size:0.78rem;">@a.CustomerName</div>
                                }
                                <div class="text-muted" style="font-size:0.75rem;">@a.ActivityDate.ToString("dd.MM.yyyy")</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (Model.DealsByStatus.Any())
{
    <div class="row g-3 mt-1">
        <div class="col-12">
            <div class="card">
                <div class="card-header py-3">
                    <i class="fas fa-chart-bar text-primary me-2"></i>Bitimlar holat bo'yicha
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        @foreach (var kv in Model.DealsByStatus)
                        {
                            <div class="col-6 col-md-4 col-xl-2">
                                <div class="text-center p-3 rounded-3 bg-light">
                                    <div class="fs-4 fw-bold text-primary">@kv.Value</div>
                                    <div class="small text-muted">@kv.Key</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
