<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Wholesale CRM</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="sidebar">
        <div class="sidebar-brand">
            <i class="fas fa-tshirt text-primary me-2"></i> Wholesale CRM
        </div>
        <nav class="flex-grow-1 p-2 mt-1">
            <ul class="nav flex-column gap-1">
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                        <i class="fas fa-chart-pie"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Customers" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ? "active" : "")">
                        <i class="fas fa-building"></i> Mijozlar
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Contacts" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contacts" ? "active" : "")">
                        <i class="fas fa-address-book"></i> Kontaktlar
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Deals" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Deals" ? "active" : "")">
                        <i class="fas fa-handshake"></i> Bitimlar
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Products" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")">
                        <i class="fas fa-tags"></i> Mahsulotlar
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Activities" asp-action="Index"
                       class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Activities" ? "active" : "")">
                        <i class="fas fa-history"></i> Faoliyatlar
                    </a>
                </li>
            </ul>
        </nav>
        <div class="sidebar-footer">
            <div class="d-flex align-items-center gap-2 mb-2">
                <div class="stat-icon bg-primary bg-opacity-25 text-primary" style="width:36px;height:36px;font-size:1rem;">
                    <i class="fas fa-user"></i>
                </div>
                <div>
                    <div class="text-white small fw-semibold">@User.Identity?.Name</div>
                    <div class="text-secondary" style="font-size:0.75rem;">Foydalanuvchi</div>
                </div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button class="btn btn-sm btn-outline-secondary w-100 text-start">
                    <i class="fas fa-sign-out-alt me-1"></i> Chiqish
                </button>
            </form>
        </div>
    </div>

    <div class="main-wrapper">
        <div class="topbar">
            <h6 class="mb-0 fw-semibold text-dark">@ViewData["Title"]</h6>
            <div class="d-flex align-items-center gap-2">
                <a asp-controller="Activities" asp-action="Create" class="btn btn-sm btn-outline-primary">
                    <i class="fas fa-plus me-1"></i> Faoliyat
                </a>
                <a asp-controller="Deals" asp-action="Create" class="btn btn-sm btn-primary">
                    <i class="fas fa-plus me-1"></i> Bitim
                </a>
            </div>
        </div>
        <div class="content-area">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 mb-3" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-3" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
