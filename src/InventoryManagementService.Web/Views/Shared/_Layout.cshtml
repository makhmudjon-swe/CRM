<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-glass">
            <div class="container-lg">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-box-seam"></i>
                    IMS
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Inventory" asp-action="Index">
                                <i class="bi bi-collection"></i> Inventories
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Inventory" asp-action="Create">
                                    <i class="bi bi-plus-circle"></i> New
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Admin") || User.IsInRole("Creator"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-gear"></i> Admin
                                </a>
                            </li>
                        }
                    </ul>
                    <form class="search-pill me-3" asp-controller="Search" asp-action="Index" method="get">
                        <i class="bi bi-search search-icon"></i>
                        <input class="form-control" type="search" name="q" placeholder="Search..." value="@ViewBag.Query" />
                    </form>
                    <div class="d-flex align-items-center gap-2">
                        <button id="themeToggle" class="theme-toggle" type="button" title="Toggle theme">
                            <i id="themeIcon" class="bi bi-moon"></i>
                        </button>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var displayName = User.Identity.Name ?? "U";
                            <span class="user-avatar" title="@displayName">@displayName[0].ToString().ToUpper()</span>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-ghost-danger btn-sm">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-lg py-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle"></i>
                <span>@TempData["Success"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-circle"></i>
                <span>@TempData["Error"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-3 animate-in">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container-lg text-center">
            &copy; 2026 Inventory Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
