@model ErrorViewModel
@{
    ViewData["Title"] = "Xato";
}
<div class="text-center mt-5">
    <h1 class="display-4 text-danger"><i class="fas fa-exclamation-triangle"></i></h1>
    <h2>Xato yuz berdi</h2>
    <p class="text-muted">Iltimos, keyinroq qayta urinib ko'ring.</p>
    @if (Model?.ShowRequestId == true)
    {
        <p class="small text-muted">Request ID: @Model.RequestId</p>
    }
    <a href="/" class="btn btn-primary mt-3">Bosh sahifaga qaytish</a>
</div>
