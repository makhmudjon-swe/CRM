@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="empty-state" style="padding-top: 5rem;">
    <i class="bi bi-exclamation-triangle" style="font-size: 4rem; color: var(--color-danger);"></i>
    <h2 class="mt-3">Something went wrong</h2>
    <p>An error occurred while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted small">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">
        <i class="bi bi-house me-1"></i> Go Home
    </a>
</div>
