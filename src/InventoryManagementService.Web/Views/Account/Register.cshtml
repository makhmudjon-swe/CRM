@model RegisterViewModel
@{
    ViewData["Title"] = "Ro'yxatdan o'tish";
    Layout = null;
}
<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ro'yxatdan o'tish — Wholesale CRM</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        body { background: linear-gradient(135deg, #1a1f2e 0%, #2d3348 100%); min-height: 100vh; }
        .card { border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center py-4">
    <div class="container" style="max-width: 480px;">
        <div class="card border-0 p-4">
            <div class="text-center mb-4">
                <i class="fas fa-tshirt fs-1 text-primary mb-2"></i>
                <h4 class="fw-bold">Hisob yaratish</h4>
                <p class="text-muted small">Wholesale CRM ga xush kelibsiz</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold small">Ism-Familiya</label>
                    <input asp-for="FullName" class="form-control" placeholder="Nodir Toshmatov" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold small">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="email@crm.uz" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold small">Parol</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="Kamida 6 belgi" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold small">Parolni tasdiqlash</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="fas fa-user-plus me-2"></i>Ro'yxatdan o'tish
                </button>
            </form>

            <hr class="my-3" />
            <div class="text-center small text-muted">
                Hisobingiz bormi?
                <a asp-action="Login" class="text-primary text-decoration-none fw-semibold">Kiring</a>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
