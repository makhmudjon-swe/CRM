@model LoginViewModel
@{
    ViewData["Title"] = "Kirish";
    Layout = null;
}
<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kirish: Wholesale CRM</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        body { background: linear-gradient(135deg, #1a1f2e 0%, #2d3348 100%); min-height: 100vh; }
        .login-card { border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
        .brand-icon { width: 64px; height: 64px; border-radius: 16px; background: #3b5bdb; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; color: white; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center">
    <div class="container" style="max-width: 420px;">
        <div class="card login-card border-0 p-4">
            <div class="text-center mb-4">
                <div class="brand-icon mx-auto mb-3">
                    <i class="fas fa-tshirt"></i>
                </div>
                <h4 class="fw-bold">Wholesale CRM</h4>
                <p class="text-muted small">Hisobingizga kiring</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold small">Email</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="email@crm.uz" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold small">Parol</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                    <label asp-for="RememberMe" class="form-check-label small">Meni eslab qol</label>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="fas fa-sign-in-alt me-2"></i>Kirish
                </button>
            </form>

            <hr class="my-3" />
            <div class="text-center small text-muted">
                Hisobingiz yo'qmi?
                <a asp-action="Register" class="text-primary text-decoration-none fw-semibold">Ro'yxatdan o'ting</a>
            </div>

            <div class="alert alert-info small mt-3 mb-0">
                <strong>Demo kirish:</strong><br>
                Email: <code>admin@crm.uz</code><br>
                Parol: <code>Admin@123!</code>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
