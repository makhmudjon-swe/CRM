@{
    ViewData["Title"] = "Login";
}

<div class="login-card">
    <div class="card shadow-lg">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <div class="user-avatar user-avatar-lg mx-auto mb-3" style="background: var(--brand-primary);">
                    <i class="bi bi-box-seam" style="font-size: 1.5rem;"></i>
                </div>
                <h2 class="page-title">Welcome back</h2>
                <p class="page-subtitle">Sign in to your account</p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle"></i>
                    <span>@TempData["Error"]</span>
                </div>
            }

            <form asp-controller="Account" asp-action="Login" method="post" class="mb-4">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent"><i class="bi bi-envelope"></i></span>
                        <input type="email" class="form-control" id="email" name="email" placeholder="you@example.com" required />
                    </div>
                </div>
                <div class="mb-4">
                    <label for="password" class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent"><i class="bi bi-lock"></i></span>
                        <input type="password" class="form-control" id="password" name="password" placeholder="Enter password" required />
                    </div>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
                    </button>
                </div>
            </form>

            <div class="text-center text-muted mb-3">
                <small>or sign in with a social account</small>
            </div>

            <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="d-grid gap-2">
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                <button type="submit" name="provider" value="Google" class="btn btn-ghost btn-lg">
                    <i class="bi bi-google me-2"></i> Sign in with Google
                </button>
                <button type="submit" name="provider" value="Facebook" class="btn btn-ghost btn-lg">
                    <i class="bi bi-facebook me-2"></i> Sign in with Facebook
                </button>
            </form>

            <div class="mt-4 pt-3 border-top">
                <details>
                    <summary class="text-muted small" style="cursor:pointer;">
                        <i class="bi bi-info-circle me-1"></i> Demo credentials
                    </summary>
                    <div class="mt-2">
                        <table class="table table-sm small mb-0">
                            <thead><tr><th>Role</th><th>Email</th><th>Password</th></tr></thead>
                            <tbody>
                                <tr><td><span class="badge badge-soft-danger">Admin</span></td><td>admin@@inventory.com</td><td><code>admin123</code></td></tr>
                                <tr><td><span class="badge badge-soft-warning">Creator</span></td><td>creator@@inventory.com</td><td><code>creator123</code></td></tr>
                                <tr><td><span class="badge badge-soft-secondary">User</span></td><td>user@@inventory.com</td><td><code>user123</code></td></tr>
                            </tbody>
                        </table>
                    </div>
                </details>
            </div>
        </div>
    </div>
</div>
