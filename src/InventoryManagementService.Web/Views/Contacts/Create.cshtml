@model ContactRequest
@{
    ViewData["Title"] = "Yangi kontakt";
}

<div class="row justify-content-center">
    <div class="col-xl-7">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item"><a asp-controller="Customers" asp-action="Index">Mijozlar</a></li>
                <li class="breadcrumb-item active">Yangi kontakt</li>
            </ol>
        </nav>
        <div class="card">
            <div class="card-header py-3"><i class="fas fa-user-plus text-primary me-2"></i>Yangi kontakt</div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label">Ism *</label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label">Familiya *</label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" type="email" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label">Telefon</label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Position" class="form-label">Lavozim</label>
                            <input asp-for="Position" class="form-control" placeholder="Direktor, Menejer..." />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CustomerId" class="form-label">Kompaniya *</label>
                            <select asp-for="CustomerId" asp-items="ViewBag.Customers" class="form-select">
                                <option value="">— Tanlang —</option>
                            </select>
                            <span asp-validation-for="CustomerId" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="IsPrimary" class="form-check-input" type="checkbox" />
                                <label asp-for="IsPrimary" class="form-check-label">Asosiy kontakt</label>
                            </div>
                        </div>
                    </div>
                    <hr class="my-4" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-2"></i>Saqlash</button>
                        <a asp-controller="Customers" asp-action="Index" class="btn btn-outline-secondary">Bekor qilish</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
