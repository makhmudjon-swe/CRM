@using InventoryManagementService.Application.DTOs
@using InventoryManagementService.Domain.Entities
@{
    ViewData["Title"] = "Admin Panel";
    var users = ViewBag.Users as List<ApplicationUser> ?? new List<ApplicationUser>();
    var userRoles = ViewBag.UserRoles as Dictionary<string, string> ?? new Dictionary<string, string>();
    var inventories = ViewBag.Inventories as IEnumerable<InventoryDto> ?? Enumerable.Empty<InventoryDto>();
}

<div class="page-header">
    <h2 class="page-title"><i class="bi bi-gear me-2"></i>Admin Panel</h2>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-people"></i></div>
            <div class="stat-number">@users.Count</div>
            <div class="stat-label">Total Users</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-collection"></i></div>
            <div class="stat-number">@inventories.Count()</div>
            <div class="stat-label">Total Inventories</div>
        </div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-circle"></i>
        <span>@TempData["Error"]</span>
    </div>
}

<ul class="nav nav-tabs mb-4" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#usersTab">
            <i class="bi bi-people me-1"></i> Users (@users.Count)
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#inventoriesTab">
            <i class="bi bi-collection me-1"></i> Inventories (@inventories.Count())
        </button>
    </li>
</ul>

<div class="tab-content">
    <div class="tab-pane fade show active" id="usersTab">
        <div class="table-container">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Name</th><th>Email</th><th>Role</th><th>Manage Access</th><th>Status</th><th>Registered</th><th>Actions</th></tr>
                </thead>
                <tbody class="stagger-in">
                    @foreach (var user in users)
                    {
                        var currentRole = userRoles.GetValueOrDefault(user.Id, "User");
                        var canManage = currentRole == "Admin" || currentRole == "Creator" || user.CanManageInventories;
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="user-avatar" style="width:1.75rem;height:1.75rem;font-size:0.65rem;">@((user.DisplayName ?? "N")[0])</span>
                                    <span>@(user.DisplayName ?? "N/A")</span>
                                </div>
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                <form asp-action="ChangeRole" method="post" class="d-flex align-items-center gap-1">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <select name="role" class="form-select form-select-sm" style="width:auto;" onchange="this.form.submit()">
                                        <option value="Admin" selected="@(currentRole == "Admin")">Admin</option>
                                        <option value="Creator" selected="@(currentRole == "Creator")">Creator</option>
                                        <option value="User" selected="@(currentRole == "User")">User</option>
                                    </select>
                                </form>
                            </td>
                            <td>
                                @if (currentRole == "Admin" || currentRole == "Creator")
                                {
                                    <span class="badge badge-soft-primary">Full Access</span>
                                }
                                else
                                {
                                    <form asp-action="ToggleManageAccess" method="post" class="d-inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        @if (canManage)
                                        {
                                            <button type="submit" class="btn btn-sm badge-soft-success" style="border:none; cursor:pointer;">
                                                <i class="bi bi-check-circle me-1"></i>Granted
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm badge-soft-secondary" style="border:none; cursor:pointer;">
                                                <i class="bi bi-x-circle me-1"></i>Not Granted
                                            </button>
                                        }
                                    </form>
                                }
                            </td>
                            <td>
                                @if (user.IsBlocked)
                                {
                                    <span class="badge badge-soft-danger">Blocked</span>
                                }
                                else
                                {
                                    <span class="badge badge-soft-success">Active</span>
                                }
                            </td>
                            <td class="text-muted">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="action-buttons">
                                    <form asp-action="ToggleBlock" method="post" class="d-inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm @(user.IsBlocked ? "btn-ghost" : "btn-ghost")">
                                            <i class="bi bi-@(user.IsBlocked ? "unlock" : "lock") me-1"></i>@(user.IsBlocked ? "Unblock" : "Block")
                                        </button>
                                    </form>
                                    <a asp-action="UserDetails" asp-route-id="@user.Id" class="btn btn-sm btn-ghost">
                                        <i class="bi bi-eye me-1"></i>Details
                                    </a>
                                    <form asp-action="DeleteUser" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this user? This cannot be undone.')">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-ghost-danger">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="tab-pane fade" id="inventoriesTab">
        <div class="table-container">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Name</th><th>Owner</th><th>Items</th><th>Public</th><th>Actions</th></tr>
                </thead>
                <tbody class="stagger-in">
                    @foreach (var inv in inventories)
                    {
                        <tr>
                            <td><a asp-controller="Inventory" asp-action="Details" asp-route-id="@inv.Id"><strong>@inv.Name</strong></a></td>
                            <td>@inv.OwnerName</td>
                            <td><span class="badge badge-soft-info">@inv.ItemCount</span></td>
                            <td>
                                @if (inv.IsPublic)
                                {
                                    <span class="badge badge-soft-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge badge-soft-secondary">No</span>
                                }
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-controller="Inventory" asp-action="Edit" asp-route-id="@inv.Id" class="btn btn-sm btn-ghost">
                                        <i class="bi bi-pencil me-1"></i>Edit
                                    </a>
                                    <form asp-action="DeleteInventory" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this inventory?')">
                                        <input type="hidden" name="id" value="@inv.Id" />
                                        <button type="submit" class="btn btn-sm btn-ghost-danger">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
