@using InventoryManagementService.Application.DTOs
@using InventoryManagementService.Domain.Entities
@{
    ViewData["Title"] = "User Details";
    var user = ViewBag.TargetUser as ApplicationUser;
    var userRole = ViewBag.UserRole as string ?? "User";
    var canManage = userRole == "Admin" || userRole == "Creator" || (user?.CanManageInventories ?? false);
    var inventories = ViewBag.UserInventories as List<InventoryDto> ?? new List<InventoryDto>();
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Admin Panel</a></li>
        <li class="breadcrumb-item active">User Details</li>
    </ol>
</nav>

@if (user != null)
{
    <div class="page-header">
        <div class="d-flex align-items-center gap-3">
            <span class="user-avatar user-avatar-lg">@((user.DisplayName ?? "N")[0])</span>
            <div>
                <h2 class="page-title">@(user.DisplayName ?? "N/A")</h2>
                <p class="page-subtitle mb-0">@user.Email</p>
            </div>
        </div>
        <div class="action-buttons">
            <form asp-action="ToggleBlock" method="post" class="d-inline">
                <input type="hidden" name="userId" value="@user.Id" />
                <button type="submit" class="btn btn-ghost btn-sm">
                    <i class="bi bi-@(user.IsBlocked ? "unlock" : "lock") me-1"></i>
                    @(user.IsBlocked ? "Unblock" : "Block")
                </button>
            </form>
            <form asp-action="DeleteUser" method="post" class="d-inline"
                  onsubmit="return confirm('Delete this user? This cannot be undone.')">
                <input type="hidden" name="userId" value="@user.Id" />
                <button type="submit" class="btn btn-ghost-danger btn-sm">
                    <i class="bi bi-trash me-1"></i> Delete User
                </button>
            </form>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header"><i class="bi bi-person me-1"></i> User Information</div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <th>Status</th>
                            <td>
                                @if (user.IsBlocked)
                                {
                                    <span class="badge badge-soft-danger">Blocked</span>
                                }
                                else
                                {
                                    <span class="badge badge-soft-success">Active</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Role</th>
                            <td>
                                <form asp-action="ChangeRole" method="post" class="d-flex align-items-center gap-2">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <select name="role" class="form-select form-select-sm" style="width:auto;">
                                        <option value="Admin" selected="@(userRole == "Admin")">Admin</option>
                                        <option value="Creator" selected="@(userRole == "Creator")">Creator</option>
                                        <option value="User" selected="@(userRole == "User")">User</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-primary">Change</button>
                                </form>
                            </td>
                        </tr>
                        <tr>
                            <th>Manage Access</th>
                            <td>
                                @if (userRole == "Admin" || userRole == "Creator")
                                {
                                    <span class="badge badge-soft-primary">Full Access</span>
                                }
                                else
                                {
                                    <form asp-action="ToggleManageAccess" method="post" class="d-inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        @if (canManage)
                                        {
                                            <button type="submit" class="btn btn-sm badge-soft-success" style="border:none;cursor:pointer;">
                                                <i class="bi bi-check-circle me-1"></i>Granted - Click to Revoke
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm badge-soft-secondary" style="border:none;cursor:pointer;">
                                                <i class="bi bi-x-circle me-1"></i>Not Granted - Click to Grant
                                            </button>
                                        }
                                    </form>
                                }
                            </td>
                        </tr>
                        <tr><th>Registered</th><td class="text-muted">@user.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td></tr>
                        <tr><th>Last Login</th><td class="text-muted">@(user.LastLoginAt?.ToString("MMM dd, yyyy HH:mm") ?? "Never")</td></tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            @if (!canManage)
            {
                <div class="card mb-3">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-shield-exclamation d-block mb-2" style="font-size:2rem; color:var(--color-warning);"></i>
                        <p class="text-muted mb-2">This user cannot create or manage inventories.</p>
                        <form asp-action="ToggleManageAccess" method="post">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="bi bi-shield-check me-1"></i> Grant Manage Access
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="divider"></div>

    <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="mb-0"><i class="bi bi-collection me-2"></i>Owned Inventories (@inventories.Count)</h4>
    </div>

    @if (inventories.Any())
    {
        <div class="table-container">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Name</th><th>Category</th><th>Items</th><th>Public</th><th>Created</th></tr>
                </thead>
                <tbody class="stagger-in">
                    @foreach (var inv in inventories)
                    {
                        <tr>
                            <td><a asp-controller="Inventory" asp-action="Details" asp-route-id="@inv.Id"><strong>@inv.Name</strong></a></td>
                            <td><i class="bi bi-folder2 me-1 text-muted"></i>@inv.CategoryName</td>
                            <td><span class="badge badge-soft-info">@inv.ItemCount</span></td>
                            <td>
                                @if (inv.IsPublic)
                                {
                                    <span class="badge badge-soft-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge badge-soft-secondary">No</span>
                                }
                            </td>
                            <td class="text-muted">@inv.CreatedAt.ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-collection"></i>
            <h5>No inventories</h5>
            @if (canManage)
            {
                <p>This user hasn't created any inventories yet.</p>
            }
            else
            {
                <p>This user doesn't have manage access. Grant it above to let them create inventories.</p>
            }
        </div>
    }
}
