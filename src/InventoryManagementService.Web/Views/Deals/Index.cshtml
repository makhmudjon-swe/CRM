@model IEnumerable<DealDto>
@{
    ViewData["Title"] = "Bitimlar Pipeline";
    var statuses = new[] {
        new { Val = 0, Name = "Yangi Lead", Color = "secondary" },
        new { Val = 1, Name = "Qualified", Color = "info" },
        new { Val = 2, Name = "Taklif", Color = "primary" },
        new { Val = 3, Name = "Muzokaralar", Color = "warning" },
        new { Val = 4, Name = "Yutildi", Color = "success" },
        new { Val = 5, Name = "Yutqizildi", Color = "danger" },
    };
}

<div class="page-header d-flex align-items-center justify-content-between">
    <div>
        <h5 class="mb-0 fw-bold">Bitimlar Pipeline</h5>
        <p class="text-muted small mb-0">Jami @Model.Count() ta bitim</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Yangi bitim</a>
</div>

<div class="row g-2 mt-1" style="overflow-x:auto;flex-wrap:nowrap;">
    @foreach (var status in statuses)
    {
        var deals = Model.Where(d => d.StatusValue == status.Val).ToList();
        <div class="col" style="min-width:220px;">
            <div class="card h-100">
                <div class="card-header py-2 bg-@(status.Color) bg-opacity-10 text-@(status.Color) border-bottom border-@(status.Color) border-opacity-25">
                    <div class="d-flex align-items-center justify-content-between">
                        <span class="fw-semibold small">@status.Name</span>
                        <span class="badge bg-@(status.Color)">@deals.Count</span>
                    </div>
                    <div class="small text-muted mt-1">
                        @(deals.Sum(d => d.TotalAmount).ToString("N0")) so'm
                    </div>
                </div>
                <div class="card-body p-2" style="max-height:65vh;overflow-y:auto;">
                    @foreach (var d in deals)
                    {
                        <div class="deal-card card mb-2 border-@(status.Color) border-opacity-50">
                            <div class="card-body p-2">
                                <a asp-action="Details" asp-route-id="@d.Id"
                                   class="text-decoration-none text-dark fw-semibold small d-block mb-1">
                                    @d.Title
                                </a>
                                <div class="text-muted" style="font-size:0.75rem;">@d.CustomerName</div>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <span class="fw-bold small text-success">@(d.TotalAmount.ToString("N0"))</span>
                                    <a asp-action="Edit" asp-route-id="@d.Id"
                                       class="btn btn-sm btn-outline-secondary p-0 px-1" style="font-size:0.7rem;">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                </div>
                                @if (d.ExpectedCloseDate.HasValue)
                                {
                                    <div class="text-muted mt-1" style="font-size:0.72rem;">
                                        <i class="fas fa-calendar me-1"></i>@d.ExpectedCloseDate.Value.ToString("dd.MM.yyyy")
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    @if (!deals.Any())
                    {
                        <p class="text-muted text-center small py-3">Bitimlar yo'q</p>
                    }
                </div>
            </div>
        </div>
    }
</div>
