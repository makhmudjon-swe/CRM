@model DealDto
@{
    ViewData["Title"] = Model.Title;
}

<div class="page-header d-flex align-items-start justify-content-between">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small mb-1">
                <li class="breadcrumb-item"><a asp-action="Index">Bitimlar</a></li>
                <li class="breadcrumb-item active">@Model.Title</li>
            </ol>
        </nav>
        <h5 class="mb-1 fw-bold">@Model.Title</h5>
        <span class="badge bg-@(WholesaleCRM.Application.EnumHelper.GetDealStatusBadge(Model.StatusValue)) fs-6">@Model.Status</span>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-pen me-1"></i>Tahrirlash
        </a>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
              onsubmit="return confirm('O\'chirilsinmi?')">
            <button class="btn btn-outline-danger btn-sm"><i class="fas fa-trash me-1"></i>O'chirish</button>
        </form>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header py-3"><i class="fas fa-info-circle text-primary me-2"></i>Bitim ma'lumotlari</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Mijoz</dt>
                    <dd class="col-7">
                        <a asp-controller="Customers" asp-action="Details" asp-route-id="@Model.CustomerId"
                           class="text-decoration-none">@Model.CustomerName</a>
                    </dd>
                    <dt class="col-5 text-muted">Summa</dt>
                    <dd class="col-7 fw-bold text-success fs-6">@(Model.TotalAmount.ToString("N0")) so'm</dd>
                    <dt class="col-5 text-muted">Holat</dt>
                    <dd class="col-7">
                        <span class="badge bg-@(WholesaleCRM.Application.EnumHelper.GetDealStatusBadge(Model.StatusValue))">@Model.Status</span>
                    </dd>
                    <dt class="col-5 text-muted">Mas'ul</dt>
                    <dd class="col-7">@(Model.AssignedToName ?? "—")</dd>
                    <dt class="col-5 text-muted">Yopilish</dt>
                    <dd class="col-7">@(Model.ExpectedCloseDate?.ToString("dd.MM.yyyy") ?? "—")</dd>
                    <dt class="col-5 text-muted">Yaratilgan</dt>
                    <dd class="col-7">@Model.CreatedAt.ToString("dd.MM.yyyy")</dd>
                </dl>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr />
                    <p class="small text-muted mb-0">@Model.Notes</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        @if (Model.Products.Any())
        {
            <div class="card">
                <div class="card-header py-3"><i class="fas fa-tags text-primary me-2"></i>Mahsulotlar</div>
                <div class="card-body p-0">
                    <table class="table mb-0 small">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Mahsulot</th>
                                <th>Miqdor</th>
                                <th>Narx</th>
                                <th>Chegirma</th>
                                <th>Jami</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Products)
                            {
                                <tr>
                                    <td class="ps-3">@p.ProductName</td>
                                    <td>@p.Quantity</td>
                                    <td>@(p.UnitPrice.ToString("N0"))</td>
                                    <td>@p.Discount%</td>
                                    <td class="fw-bold">@(p.TotalPrice.ToString("N0"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
