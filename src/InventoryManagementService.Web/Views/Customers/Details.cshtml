@model CustomerDto
@{
    ViewData["Title"] = Model.CompanyName;
}

<div class="page-header d-flex align-items-start justify-content-between">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small mb-1">
                <li class="breadcrumb-item"><a asp-action="Index">Mijozlar</a></li>
                <li class="breadcrumb-item active">@Model.CompanyName</li>
            </ol>
        </nav>
        <h5 class="mb-0 fw-bold">@Model.CompanyName</h5>
        <span class="badge bg-@(WholesaleCRM.Application.EnumHelper.GetCustomerStatusBadge(Model.StatusValue))">@Model.Status</span>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Activities" asp-action="Create" asp-route-customerId="@Model.Id"
           class="btn btn-outline-primary btn-sm"><i class="fas fa-plus me-1"></i>Faoliyat</a>
        <a asp-controller="Contacts" asp-action="Create" asp-route-customerId="@Model.Id"
           class="btn btn-outline-secondary btn-sm"><i class="fas fa-plus me-1"></i>Kontakt</a>
        <a asp-controller="Deals" asp-action="Create" asp-route-customerId="@Model.Id"
           class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Bitim</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-pen"></i>
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Info Card -->
    <div class="col-xl-4">
        <div class="card">
            <div class="card-header py-3"><i class="fas fa-info-circle text-primary me-2"></i>Ma'lumotlar</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5 text-muted">Soha</dt>
                    <dd class="col-7">@(Model.Industry ?? "—")</dd>
                    <dt class="col-5 text-muted">Email</dt>
                    <dd class="col-7">@(Model.Email ?? "—")</dd>
                    <dt class="col-5 text-muted">Telefon</dt>
                    <dd class="col-7">@(Model.Phone ?? "—")</dd>
                    <dt class="col-5 text-muted">Shahar</dt>
                    <dd class="col-7">@(Model.City ?? "—"), @(Model.Country ?? "")</dd>
                    <dt class="col-5 text-muted">Manzil</dt>
                    <dd class="col-7">@(Model.Address ?? "—")</dd>
                    <dt class="col-5 text-muted">Mas'ul</dt>
                    <dd class="col-7">@(Model.AssignedToName ?? "—")</dd>
                    <dt class="col-5 text-muted">Yaratilgan</dt>
                    <dd class="col-7">@Model.CreatedAt.ToString("dd.MM.yyyy")</dd>
                </dl>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr />
                    <div class="small text-muted">@Model.Notes</div>
                }
            </div>
        </div>

        <!-- Stats -->
        <div class="row g-2 mt-1">
            <div class="col-6">
                <div class="card text-center p-3">
                    <div class="fs-4 fw-bold text-primary">@Model.DealCount</div>
                    <div class="small text-muted">Bitimlar</div>
                </div>
            </div>
            <div class="col-6">
                <div class="card text-center p-3">
                    <div class="fs-4 fw-bold text-success">@(Model.TotalRevenue.ToString("N0"))</div>
                    <div class="small text-muted">Daromad</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <!-- Contacts -->
        <div class="card mb-3">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <span><i class="fas fa-address-book text-primary me-2"></i>Kontaktlar (@Model.Contacts.Count)</span>
                <a asp-controller="Contacts" asp-action="Create" asp-route-customerId="@Model.Id"
                   class="btn btn-sm btn-outline-primary"><i class="fas fa-plus me-1"></i>Qo'shish</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Ism</th>
                            <th>Lavozim</th>
                            <th>Email</th>
                            <th>Telefon</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Contacts)
                        {
                            <tr>
                                <td class="ps-3 fw-semibold">
                                    @c.FullName
                                    @if (c.IsPrimary) { <span class="badge bg-primary ms-1" style="font-size:0.65rem;">Asosiy</span> }
                                </td>
                                <td class="text-muted">@(c.Position ?? "—")</td>
                                <td>@(c.Email ?? "—")</td>
                                <td>@(c.Phone ?? "—")</td>
                                <td>
                                    <a asp-controller="Contacts" asp-action="Edit" asp-route-id="@c.Id"
                                       class="btn btn-sm btn-outline-secondary"><i class="fas fa-pen"></i></a>
                                    <form asp-controller="Contacts" asp-action="Delete" asp-route-id="@c.Id"
                                          asp-route-customerId="@Model.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('O\'chirilsinmi?')">
                                        <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.Contacts.Any())
                        {
                            <tr><td colspan="5" class="text-center py-3 text-muted">Kontaktlar yo'q</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Deals -->
        <div class="card mb-3">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <span><i class="fas fa-handshake text-primary me-2"></i>Bitimlar (@Model.Deals.Count)</span>
                <a asp-controller="Deals" asp-action="Create" asp-route-customerId="@Model.Id"
                   class="btn btn-sm btn-outline-primary"><i class="fas fa-plus me-1"></i>Qo'shish</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Bitim</th>
                            <th>Holat</th>
                            <th>Summa</th>
                            <th>Yopilish</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Deals)
                        {
                            <tr>
                                <td class="ps-3">
                                    <a asp-controller="Deals" asp-action="Details" asp-route-id="@d.Id"
                                       class="text-decoration-none fw-semibold text-dark">@d.Title</a>
                                </td>
                                <td>
                                    <span class="badge bg-@(WholesaleCRM.Application.EnumHelper.GetDealStatusBadge(d.StatusValue))">
                                        @d.Status
                                    </span>
                                </td>
                                <td class="fw-semibold">@(d.TotalAmount.ToString("N0"))</td>
                                <td class="text-muted">@(d.ExpectedCloseDate?.ToString("dd.MM.yy") ?? "—")</td>
                                <td>
                                    <a asp-controller="Deals" asp-action="Edit" asp-route-id="@d.Id"
                                       class="btn btn-sm btn-outline-secondary"><i class="fas fa-pen"></i></a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Deals.Any())
                        {
                            <tr><td colspan="5" class="text-center py-3 text-muted">Bitimlar yo'q</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Activities -->
        <div class="card">
            <div class="card-header py-3 d-flex align-items-center justify-content-between">
                <span><i class="fas fa-history text-primary me-2"></i>Faoliyatlar (@Model.Activities.Count)</span>
                <a asp-controller="Activities" asp-action="Create" asp-route-customerId="@Model.Id"
                   class="btn btn-sm btn-outline-primary"><i class="fas fa-plus me-1"></i>Qo'shish</a>
            </div>
            <div class="card-body">
                @foreach (var a in Model.Activities.Take(10))
                {
                    <div class="activity-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="badge bg-light text-dark border me-2">
                                    <i class="fas @a.TypeIcon me-1 text-primary"></i>@a.Type
                                </span>
                                <span class="fw-semibold small">@a.Subject</span>
                                @if (!string.IsNullOrEmpty(a.Notes))
                                {
                                    <div class="text-muted small mt-1">@a.Notes</div>
                                }
                            </div>
                            <div class="text-end">
                                <div class="text-muted small">@a.ActivityDate.ToString("dd.MM.yyyy")</div>
                                @if (!string.IsNullOrEmpty(a.UserName))
                                {
                                    <div class="text-muted" style="font-size:0.75rem;">@a.UserName</div>
                                }
                            </div>
                        </div>
                    </div>
                }
                @if (!Model.Activities.Any())
                {
                    <p class="text-muted text-center py-2">Faoliyatlar yo'q</p>
                }
            </div>
        </div>
    </div>
</div>
