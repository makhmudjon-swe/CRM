@using InventoryManagementService.Application.DTOs
@model CreateItemDto
@{
    var inventory = ViewBag.Inventory as InventoryDto;
    ViewData["Title"] = "Add Item";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Inventory" asp-action="Index">Inventories</a></li>
        <li class="breadcrumb-item"><a asp-controller="Inventory" asp-action="Details" asp-route-id="@inventory?.Id">@inventory?.Name</a></li>
        <li class="breadcrumb-item active">Add Item</li>
    </ol>
</nav>

<div class="page-header">
    <h2 class="page-title"><i class="bi bi-plus-circle me-2"></i>Add Item to @inventory?.Name</h2>
</div>

<form asp-action="Create" method="post">
    <input type="hidden" asp-for="InventoryId" />

    <div class="card mb-4">
        <div class="card-header">Item Details</div>
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Item Name *</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            @if (inventory?.CustomString1Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomString1Name</label>
                    <input asp-for="CustomString1Value" class="form-control" />
                </div>
            }
            @if (inventory?.CustomString2Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomString2Name</label>
                    <input asp-for="CustomString2Value" class="form-control" />
                </div>
            }
            @if (inventory?.CustomString3Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomString3Name</label>
                    <input asp-for="CustomString3Value" class="form-control" />
                </div>
            }
            @if (inventory?.CustomText1Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomText1Name</label>
                    <textarea asp-for="CustomText1Value" class="form-control" rows="3"></textarea>
                </div>
            }
            @if (inventory?.CustomText2Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomText2Name</label>
                    <textarea asp-for="CustomText2Value" class="form-control" rows="3"></textarea>
                </div>
            }
            @if (inventory?.CustomText3Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomText3Name</label>
                    <textarea asp-for="CustomText3Value" class="form-control" rows="3"></textarea>
                </div>
            }
            @if (inventory?.CustomInt1Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomInt1Name</label>
                    <input asp-for="CustomInt1Value" type="number" class="form-control" />
                </div>
            }
            @if (inventory?.CustomInt2Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomInt2Name</label>
                    <input asp-for="CustomInt2Value" type="number" class="form-control" />
                </div>
            }
            @if (inventory?.CustomInt3Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomInt3Name</label>
                    <input asp-for="CustomInt3Value" type="number" class="form-control" />
                </div>
            }
            @if (inventory?.CustomLink1Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomLink1Name</label>
                    <input asp-for="CustomLink1Value" type="url" class="form-control" placeholder="https://..." />
                </div>
            }
            @if (inventory?.CustomLink2Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomLink2Name</label>
                    <input asp-for="CustomLink2Value" type="url" class="form-control" placeholder="https://..." />
                </div>
            }
            @if (inventory?.CustomLink3Enabled == true)
            {
                <div class="mb-3">
                    <label class="form-label">@inventory.CustomLink3Name</label>
                    <input asp-for="CustomLink3Value" type="url" class="form-control" placeholder="https://..." />
                </div>
            }
            @if (inventory?.CustomBool1Enabled == true)
            {
                <div class="mb-3 form-check">
                    <input type="checkbox" name="CustomBool1Value" class="form-check-input" value="true" />
                    <label class="form-check-label">@inventory.CustomBool1Name</label>
                </div>
            }
            @if (inventory?.CustomBool2Enabled == true)
            {
                <div class="mb-3 form-check">
                    <input type="checkbox" name="CustomBool2Value" class="form-check-input" value="true" />
                    <label class="form-check-label">@inventory.CustomBool2Name</label>
                </div>
            }
            @if (inventory?.CustomBool3Enabled == true)
            {
                <div class="mb-3 form-check">
                    <input type="checkbox" name="CustomBool3Value" class="form-check-input" value="true" />
                    <label class="form-check-label">@inventory.CustomBool3Name</label>
                </div>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> Add Item
        </button>
        <a asp-controller="Inventory" asp-action="Details" asp-route-id="@inventory?.Id" class="btn btn-ghost">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
