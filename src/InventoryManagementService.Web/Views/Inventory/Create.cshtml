@using InventoryManagementService.Application.DTOs
@model CreateInventoryDto
@{
    ViewData["Title"] = "Create Inventory";
    var categories = ViewBag.Categories as IEnumerable<CategoryDto> ?? Enumerable.Empty<CategoryDto>();
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Inventory" asp-action="Index">Inventories</a></li>
        <li class="breadcrumb-item active">Create</li>
    </ol>
</nav>

<div class="page-header">
    <h2 class="page-title"><i class="bi bi-plus-circle me-2"></i>Create Inventory</h2>
</div>

<form asp-action="Create" method="post">
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header">Basic Information</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Name *</label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <small class="text-muted ms-1">Markdown supported</small>
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">Category *</label>
                        <select asp-for="CategoryId" class="form-select" required>
                            <option value="">Select category...</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Image</label>
                        <input type="file" id="imageFile" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp" />
                        <input type="hidden" asp-for="ImageUrl" id="imageUrlHidden" />
                        <div id="imagePreview" class="mt-2" style="display:none;">
                            <img id="imagePreviewImg" src="" alt="Preview" class="img-thumbnail" style="max-height:200px;" />
                            <button type="button" id="removeImage" class="btn btn-sm btn-ghost-danger ms-2"><i class="bi bi-x-lg"></i> Remove</button>
                        </div>
                        <div id="imageUploadStatus" class="small mt-1"></div>
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="IsPublic" class="form-check-input" />
                        <label asp-for="IsPublic" class="form-check-label">
                            Public inventory
                        </label>
                        <div class="form-text">Any authenticated user can add, edit, and delete items.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tags</label>
                        <small class="text-muted ms-1">comma-separated</small>
                        <input type="text" id="tagsInput" class="form-control" placeholder="electronics, vintage, rare..." />
                        <div id="tagsSuggestions" class="list-group position-absolute" style="z-index:1000;"></div>
                    </div>
                    <div id="tagsHidden"></div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-sliders me-1"></i> Custom Fields</div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Enable up to 15 custom fields for items. Check to enable, then give it a label.</p>

                    <h6 class="text-muted mb-2"><i class="bi bi-fonts me-1"></i> Short Text <small class="fw-normal">(single line)</small></h6>
                    @for (int i = 1; i <= 3; i++)
                    {
                        <div class="border rounded p-2 mb-2 custom-field-row">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input custom-field-toggle" name="CustomString@(i)Enabled" value="true" id="cs@(i)">
                                <label class="form-check-label" for="cs@(i)">Field @i</label>
                            </div>
                            <input type="text" class="form-control form-control-sm mt-1 custom-field-name" name="CustomString@(i)Name" placeholder="e.g. Brand, Color, SKU..." style="display:none;" />
                        </div>
                    }

                    <h6 class="text-muted mb-2 mt-3"><i class="bi bi-text-paragraph me-1"></i> Long Text <small class="fw-normal">(multiline)</small></h6>
                    @for (int i = 1; i <= 3; i++)
                    {
                        <div class="border rounded p-2 mb-2 custom-field-row">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input custom-field-toggle" name="CustomText@(i)Enabled" value="true" id="ct@(i)">
                                <label class="form-check-label" for="ct@(i)">Field @i</label>
                            </div>
                            <input type="text" class="form-control form-control-sm mt-1 custom-field-name" name="CustomText@(i)Name" placeholder="e.g. Notes, Description, History..." style="display:none;" />
                        </div>
                    }

                    <h6 class="text-muted mb-2 mt-3"><i class="bi bi-123 me-1"></i> Number <small class="fw-normal">(integer)</small></h6>
                    @for (int i = 1; i <= 3; i++)
                    {
                        <div class="border rounded p-2 mb-2 custom-field-row">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input custom-field-toggle" name="CustomInt@(i)Enabled" value="true" id="ci@(i)">
                                <label class="form-check-label" for="ci@(i)">Field @i</label>
                            </div>
                            <input type="text" class="form-control form-control-sm mt-1 custom-field-name" name="CustomInt@(i)Name" placeholder="e.g. Quantity, Year, Price..." style="display:none;" />
                        </div>
                    }

                    <h6 class="text-muted mb-2 mt-3"><i class="bi bi-link-45deg me-1"></i> Link <small class="fw-normal">(URL)</small></h6>
                    @for (int i = 1; i <= 3; i++)
                    {
                        <div class="border rounded p-2 mb-2 custom-field-row">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input custom-field-toggle" name="CustomLink@(i)Enabled" value="true" id="cl@(i)">
                                <label class="form-check-label" for="cl@(i)">Field @i</label>
                            </div>
                            <input type="text" class="form-control form-control-sm mt-1 custom-field-name" name="CustomLink@(i)Name" placeholder="e.g. Website, Manual, Source..." style="display:none;" />
                        </div>
                    }

                    <h6 class="text-muted mb-2 mt-3"><i class="bi bi-toggle-on me-1"></i> Yes / No <small class="fw-normal">(checkbox)</small></h6>
                    @for (int i = 1; i <= 3; i++)
                    {
                        <div class="border rounded p-2 mb-2 custom-field-row">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input custom-field-toggle" name="CustomBool@(i)Enabled" value="true" id="cb@(i)">
                                <label class="form-check-label" for="cb@(i)">Field @i</label>
                            </div>
                            <input type="text" class="form-control form-control-sm mt-1 custom-field-name" name="CustomBool@(i)Name" placeholder="e.g. In Stock, Verified, Featured..." style="display:none;" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="mb-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> Create Inventory
        </button>
        <a asp-action="Index" class="btn btn-ghost">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Image upload
        $('#imageFile').on('change', function () {
            const file = this.files[0];
            if (!file) return;
            const formData = new FormData();
            formData.append('file', file);
            $('#imageUploadStatus').text('Uploading...').removeClass('text-danger text-success');
            $.ajax({
                url: '/api/images/upload',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    $('#imageUrlHidden').val(res.url);
                    $('#imagePreviewImg').attr('src', res.url);
                    $('#imagePreview').show();
                    $('#imageUploadStatus').text('Uploaded').addClass('text-success');
                },
                error: function (xhr) {
                    const msg = xhr.responseJSON?.error || 'Upload failed';
                    $('#imageUploadStatus').text(msg).addClass('text-danger');
                }
            });
        });
        $('#removeImage').on('click', function () {
            $('#imageUrlHidden').val('');
            $('#imageFile').val('');
            $('#imagePreview').hide();
            $('#imageUploadStatus').text('');
        });

        // Tag autocomplete
        let tagTimer;
        $('#tagsInput').on('input', function () {
            clearTimeout(tagTimer);
            const val = this.value.split(',').pop().trim();
            if (val.length < 2) { $('#tagsSuggestions').empty(); return; }
            tagTimer = setTimeout(() => {
                $.get('/api/tags/search?q=' + encodeURIComponent(val), function (data) {
                    let html = '';
                    data.forEach(t => {
                        html += `<a href="#" class="list-group-item list-group-item-action tag-suggestion">${t}</a>`;
                    });
                    $('#tagsSuggestions').html(html);
                });
            }, 300);
        });
        $(document).on('click', '.tag-suggestion', function (e) {
            e.preventDefault();
            const parts = $('#tagsInput').val().split(',');
            parts.pop();
            parts.push(' ' + $(this).text());
            $('#tagsInput').val(parts.join(',') + ', ');
            $('#tagsSuggestions').empty();
            $('#tagsInput').focus();
        });
        // Custom field toggle: show/hide name input
        $('.custom-field-toggle').on('change', function () {
            const $name = $(this).closest('.custom-field-row').find('.custom-field-name');
            if (this.checked) {
                $name.slideDown(150).focus();
            } else {
                $name.slideUp(150);
            }
        });

        // Before submit, populate hidden fields
        $('form').on('submit', function () {
            $('#tagsHidden').empty();
            const tags = $('#tagsInput').val().split(',').map(t => t.trim()).filter(t => t);
            tags.forEach((t, i) => {
                $('#tagsHidden').append(`<input type="hidden" name="Tags[${i}]" value="${t}" />`);
            });
        });
    </script>
}
