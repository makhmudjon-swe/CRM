@using InventoryManagementService.Application.DTOs
@model UpdateInventoryDto
@{
    ViewData["Title"] = "Edit Inventory";
    var categories = ViewBag.Categories as IEnumerable<CategoryDto> ?? Enumerable.Empty<CategoryDto>();
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Inventory" asp-action="Index">Inventories</a></li>
        <li class="breadcrumb-item"><a asp-controller="Inventory" asp-action="Details" asp-route-id="@Model.Id">Details</a></li>
        <li class="breadcrumb-item active">Edit</li>
    </ol>
</nav>

<div class="page-header">
    <h2 class="page-title"><i class="bi bi-pencil me-2"></i>Edit Inventory</h2>
    <span id="autoSaveStatus" class="text-muted small"></span>
</div>

<form asp-action="Edit" method="post" id="editForm">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header">Basic Information</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Name *</label>
                        <input asp-for="Name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <small class="text-muted ms-1">Markdown supported</small>
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">Category *</label>
                        <select asp-for="CategoryId" class="form-select" required>
                            <option value="">Select...</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId)">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Image</label>
                        <input type="file" id="imageFile" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp" />
                        <input type="hidden" asp-for="ImageUrl" id="imageUrlHidden" />
                        <div id="imagePreview" class="mt-2" style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")">
                            <img id="imagePreviewImg" src="@Model.ImageUrl" alt="Preview" class="img-thumbnail" style="max-height:200px;" />
                            <button type="button" id="removeImage" class="btn btn-sm btn-ghost-danger ms-2"><i class="bi bi-x-lg"></i> Remove</button>
                        </div>
                        <div id="imageUploadStatus" class="small mt-1"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tags</label>
                        <input type="text" id="tagsInput" class="form-control" value="@string.Join(", ", Model.Tags)" />
                        <div id="tagsSuggestions" class="list-group position-absolute" style="z-index:1000;"></div>
                    </div>
                    <div id="tagsHidden"></div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-fingerprint me-1"></i> Custom ID Format</div>
                <div class="card-body">
                    <div class="alert alert-info small mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Configure how item IDs are auto-generated. Drag elements to reorder. Drag outside to remove.
                        Existing item IDs are not affected by format changes.
                    </div>

                    <div class="mb-3">
                        <strong>Preview:</strong>
                        <code id="idPreview" class="ms-2 fs-6">—</code>
                    </div>

                    <h6 class="mb-2">ID Elements</h6>
                    <div id="idElementsList" class="mb-3" style="min-height:40px; border:2px dashed var(--border-color); border-radius:8px; padding:8px;">
                    </div>

                    <h6 class="mb-2">Add Element</h6>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <button type="button" class="btn btn-sm btn-outline-primary add-element-btn" data-type="0"
                            data-bs-toggle="popover" data-bs-trigger="hover" data-bs-content="Any Unicode text: prefixes, separators, labels.">
                            <i class="bi bi-fonts me-1"></i>Fixed Text
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-primary add-element-btn" data-type="1"
                            data-bs-toggle="popover" data-bs-trigger="hover" data-bs-content="Auto-incrementing number. Equal to largest existing +1.">
                            <i class="bi bi-sort-numeric-up me-1"></i>Sequence
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-primary add-element-btn" data-type="2"
                            data-bs-toggle="popover" data-bs-trigger="hover" data-bs-content="Date/time when item is created. Customizable format (e.g. yyyyMMdd, yyyyMMdd-HHmmss).">
                            <i class="bi bi-calendar me-1"></i>Date/Time
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-primary add-element-btn" data-type="3"
                            data-bs-toggle="popover" data-bs-trigger="hover" data-bs-content="Random number 0–1,048,575 (20-bit). Good for short random segments.">
                            <i class="bi bi-dice-3 me-1"></i>20-bit Random
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-primary add-element-btn" data-type="4"
                            data-bs-toggle="popover" data-bs-trigger="hover" data-bs-content="Random number 0–2,147,483,647 (32-bit). Larger random range.">
                            <i class="bi bi-dice-5 me-1"></i>32-bit Random
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-primary add-element-btn" data-type="5"
                            data-bs-toggle="popover" data-bs-trigger="hover" data-bs-content="Random 6-digit number (000000–999999).">
                            <i class="bi bi-hash me-1"></i>6-Digit Random
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-primary add-element-btn" data-type="6"
                            data-bs-toggle="popover" data-bs-trigger="hover" data-bs-content="Random 9-digit number (000000000–999999999).">
                            <i class="bi bi-hash me-1"></i>9-Digit Random
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-primary add-element-btn" data-type="7"
                            data-bs-toggle="popover" data-bs-trigger="hover" data-bs-content="UUID/GUID. Use padding to truncate (e.g. 8 chars). Default: full 32 hex chars.">
                            <i class="bi bi-upc me-1"></i>GUID
                        </button>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" id="saveFormatBtn" class="btn btn-sm btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Save Format
                        </button>
                        <button type="button" id="clearFormatBtn" class="btn btn-sm btn-ghost-danger">
                            <i class="bi bi-trash me-1"></i>Clear All
                        </button>
                        <span id="formatSaveStatus" class="small align-self-center"></span>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-shield-lock me-1"></i> Access Control</div>
                <div class="card-body">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="publicToggle" @(Model.IsPublic ? "checked" : "")>
                        <label class="form-check-label" for="publicToggle">
                            Public inventory
                        </label>
                        <div class="form-text">Any authenticated user can add, edit, and delete items.</div>
                    </div>
                    <input type="hidden" asp-for="IsPublic" id="isPublicHidden" />
                    <div class="divider"></div>
                    <h6 class="mb-3"><i class="bi bi-person-plus me-1"></i> Grant Write Access</h6>
                    <div class="search-pill mb-2" style="width:100%;">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text" id="userSearchInput" class="form-control" placeholder="Search users by name or email..." style="width:100%; padding-left:2.25rem;" />
                    </div>
                    <div id="userSearchResults" class="list-group mb-3"></div>

                    <h6 class="mb-2"><i class="bi bi-people me-1"></i> Users with Access</h6>
                    <div id="accessList">
                        <p class="text-muted small">Loading...</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header"><i class="bi bi-sliders me-1"></i> Custom Fields</div>
                <div class="card-body">
                    <p class="text-muted small mb-3">Enable up to 15 custom fields for items. Check to enable, then give it a label.</p>

                    <h6 class="text-muted mb-2"><i class="bi bi-fonts me-1"></i> Short Text <small class="fw-normal">(single line)</small></h6>
                    @for (int i = 1; i <= 3; i++)
                    {
                        var enabled = (bool)(typeof(UpdateInventoryDto).GetProperty($"CustomString{i}Enabled")!.GetValue(Model) ?? false);
                        var name = (string?)(typeof(UpdateInventoryDto).GetProperty($"CustomString{i}Name")!.GetValue(Model));
                        <div class="border rounded p-2 mb-2 custom-field-row">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input custom-field-toggle" name="CustomString@(i)Enabled" value="true" id="cs@(i)" @(enabled ? "checked" : "") />
                                <label class="form-check-label" for="cs@(i)">Field @i</label>
                            </div>
                            <input type="text" class="form-control form-control-sm mt-1 custom-field-name" name="CustomString@(i)Name" value="@name" placeholder="e.g. Brand, Color, SKU..." style="@(enabled ? "" : "display:none;")" />
                        </div>
                    }

                    <h6 class="text-muted mb-2 mt-3"><i class="bi bi-text-paragraph me-1"></i> Long Text <small class="fw-normal">(multiline)</small></h6>
                    @for (int i = 1; i <= 3; i++)
                    {
                        var enabled = (bool)(typeof(UpdateInventoryDto).GetProperty($"CustomText{i}Enabled")!.GetValue(Model) ?? false);
                        var name = (string?)(typeof(UpdateInventoryDto).GetProperty($"CustomText{i}Name")!.GetValue(Model));
                        <div class="border rounded p-2 mb-2 custom-field-row">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input custom-field-toggle" name="CustomText@(i)Enabled" value="true" id="ct@(i)" @(enabled ? "checked" : "") />
                                <label class="form-check-label" for="ct@(i)">Field @i</label>
                            </div>
                            <input type="text" class="form-control form-control-sm mt-1 custom-field-name" name="CustomText@(i)Name" value="@name" placeholder="e.g. Notes, Description, History..." style="@(enabled ? "" : "display:none;")" />
                        </div>
                    }

                    <h6 class="text-muted mb-2 mt-3"><i class="bi bi-123 me-1"></i> Number <small class="fw-normal">(integer)</small></h6>
                    @for (int i = 1; i <= 3; i++)
                    {
                        var enabled = (bool)(typeof(UpdateInventoryDto).GetProperty($"CustomInt{i}Enabled")!.GetValue(Model) ?? false);
                        var name = (string?)(typeof(UpdateInventoryDto).GetProperty($"CustomInt{i}Name")!.GetValue(Model));
                        <div class="border rounded p-2 mb-2 custom-field-row">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input custom-field-toggle" name="CustomInt@(i)Enabled" value="true" id="ci@(i)" @(enabled ? "checked" : "") />
                                <label class="form-check-label" for="ci@(i)">Field @i</label>
                            </div>
                            <input type="text" class="form-control form-control-sm mt-1 custom-field-name" name="CustomInt@(i)Name" value="@name" placeholder="e.g. Quantity, Year, Price..." style="@(enabled ? "" : "display:none;")" />
                        </div>
                    }

                    <h6 class="text-muted mb-2 mt-3"><i class="bi bi-link-45deg me-1"></i> Link <small class="fw-normal">(URL)</small></h6>
                    @for (int i = 1; i <= 3; i++)
                    {
                        var enabled = (bool)(typeof(UpdateInventoryDto).GetProperty($"CustomLink{i}Enabled")!.GetValue(Model) ?? false);
                        var name = (string?)(typeof(UpdateInventoryDto).GetProperty($"CustomLink{i}Name")!.GetValue(Model));
                        <div class="border rounded p-2 mb-2 custom-field-row">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input custom-field-toggle" name="CustomLink@(i)Enabled" value="true" id="cl@(i)" @(enabled ? "checked" : "") />
                                <label class="form-check-label" for="cl@(i)">Field @i</label>
                            </div>
                            <input type="text" class="form-control form-control-sm mt-1 custom-field-name" name="CustomLink@(i)Name" value="@name" placeholder="e.g. Website, Manual, Source..." style="@(enabled ? "" : "display:none;")" />
                        </div>
                    }

                    <h6 class="text-muted mb-2 mt-3"><i class="bi bi-toggle-on me-1"></i> Yes / No <small class="fw-normal">(checkbox)</small></h6>
                    @for (int i = 1; i <= 3; i++)
                    {
                        var enabled = (bool)(typeof(UpdateInventoryDto).GetProperty($"CustomBool{i}Enabled")!.GetValue(Model) ?? false);
                        var name = (string?)(typeof(UpdateInventoryDto).GetProperty($"CustomBool{i}Name")!.GetValue(Model));
                        <div class="border rounded p-2 mb-2 custom-field-row">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input custom-field-toggle" name="CustomBool@(i)Enabled" value="true" id="cb@(i)" @(enabled ? "checked" : "") />
                                <label class="form-check-label" for="cb@(i)">Field @i</label>
                            </div>
                            <input type="text" class="form-control form-control-sm mt-1 custom-field-name" name="CustomBool@(i)Name" value="@name" placeholder="e.g. In Stock, Verified, Featured..." style="@(enabled ? "" : "display:none;")" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="mb-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> Save Changes
        </button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-ghost">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const inventoryId = @Model.Id;

        // Custom field toggle: show/hide name input
        $('.custom-field-toggle').on('change', function () {
            const $name = $(this).closest('.custom-field-row').find('.custom-field-name');
            if (this.checked) {
                $name.slideDown(150).focus();
            } else {
                $name.slideUp(150);
            }
        });

        // Public toggle
        $('#publicToggle').on('change', function () {
            const isPublic = this.checked;
            $('#isPublicHidden').val(isPublic);
            $.ajax({
                url: '/api/inventory/' + inventoryId + '/toggle-public',
                type: 'POST',
                contentType: 'application/json',
                success: function (res) {
                    $('#isPublicHidden').val(res.isPublic);
                }
            });
        });

        // Image upload
        $('#imageFile').on('change', function () {
            const file = this.files[0];
            if (!file) return;
            const formData = new FormData();
            formData.append('file', file);
            $('#imageUploadStatus').text('Uploading...').removeClass('text-danger text-success');
            $.ajax({
                url: '/api/images/upload',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    $('#imageUrlHidden').val(res.url);
                    $('#imagePreviewImg').attr('src', res.url);
                    $('#imagePreview').show();
                    $('#imageUploadStatus').text('Uploaded').addClass('text-success');
                },
                error: function (xhr) {
                    const msg = xhr.responseJSON?.error || 'Upload failed';
                    $('#imageUploadStatus').text(msg).addClass('text-danger');
                }
            });
        });
        $('#removeImage').on('click', function () {
            $('#imageUrlHidden').val('');
            $('#imageFile').val('');
            $('#imagePreview').hide();
            $('#imageUploadStatus').text('');
        });

        // User search for access grants
        function searchUsers() {
            const q = $('#userSearchInput').val().trim();
            if (q.length < 2) { $('#userSearchResults').empty(); return; }
            $.get('/api/users/search?q=' + encodeURIComponent(q), function (users) {
                let html = '';
                users.forEach(u => {
                    html += `<a href="#" class="list-group-item list-group-item-action grant-access-btn" data-user-id="${u.id}">
                        <strong>${u.displayName || 'N/A'}</strong> <small class="text-muted">${u.email}</small>
                    </a>`;
                });
                $('#userSearchResults').html(html || '<p class="text-muted p-2">No users found</p>');
            });
        }
        $('#userSearchInput').on('keyup', function (e) { if (e.key === 'Enter') searchUsers(); });

        // Grant access
        $(document).on('click', '.grant-access-btn', function (e) {
            e.preventDefault();
            const userId = $(this).data('user-id');
            $.ajax({
                url: '/api/inventory/' + inventoryId + '/access',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ userId: userId }),
                success: function () {
                    $('#userSearchResults').empty();
                    $('#userSearchInput').val('');
                    loadAccessList();
                }
            });
        });

        // Load access list
        function loadAccessList() {
            $.get('/api/inventory/' + inventoryId + '/access', function (list) {
                if (list.length === 0) {
                    $('#accessList').html('<p class="text-muted small">No users have been granted access.</p>');
                    return;
                }
                let html = '<ul class="list-group">';
                list.forEach(a => {
                    html += `<li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><strong>${a.userDisplayName || 'N/A'}</strong> <small class="text-muted">${a.userEmail}</small></span>
                        <button class="btn btn-sm btn-ghost-danger revoke-access-btn" data-user-id="${a.userId}"><i class="bi bi-x-lg"></i> Revoke</button>
                    </li>`;
                });
                html += '</ul>';
                $('#accessList').html(html);
            });
        }
        loadAccessList();

        // Revoke access
        $(document).on('click', '.revoke-access-btn', function () {
            const userId = $(this).data('user-id');
            $.ajax({
                url: '/api/inventory/' + inventoryId + '/access/' + userId,
                type: 'DELETE',
                success: function () { loadAccessList(); }
            });
        });

        // Tag autocomplete
        let tagTimer;
        $('#tagsInput').on('input', function () {
            clearTimeout(tagTimer);
            const val = this.value.split(',').pop().trim();
            if (val.length < 2) { $('#tagsSuggestions').empty(); return; }
            tagTimer = setTimeout(() => {
                $.get('/api/tags/search?q=' + encodeURIComponent(val), function (data) {
                    let html = '';
                    data.forEach(t => {
                        html += `<a href="#" class="list-group-item list-group-item-action tag-suggestion">${t}</a>`;
                    });
                    $('#tagsSuggestions').html(html);
                });
            }, 300);
        });
        $(document).on('click', '.tag-suggestion', function (e) {
            e.preventDefault();
            const parts = $('#tagsInput').val().split(',');
            parts.pop();
            parts.push(' ' + $(this).text());
            $('#tagsInput').val(parts.join(',') + ', ');
            $('#tagsSuggestions').empty();
            $('#tagsInput').focus();
        });
        $('form').on('submit', function () {
            $('#tagsHidden').empty();
            const tags = $('#tagsInput').val().split(',').map(t => t.trim()).filter(t => t);
            tags.forEach((t, i) => {
                $('#tagsHidden').append(`<input type="hidden" name="Tags[${i}]" value="${t}" />`);
            });
        });

        // Auto-save every 10 seconds
        setInterval(function () {
            const formData = new FormData($('#editForm')[0]);
            const data = {};
            formData.forEach((val, key) => { data[key] = val; });

            data.Id = parseInt(data.Id) || 0;
            data.CategoryId = parseInt(data.CategoryId) || 0;
            data.IsPublic = data.IsPublic === 'true' || data.IsPublic === 'True';
            data.Tags = $('#tagsInput').val().split(',').map(t => t.trim()).filter(t => t);

            for (let prefix of ['CustomString', 'CustomText', 'CustomInt', 'CustomLink', 'CustomBool']) {
                for (let i = 1; i <= 3; i++) {
                    const key = prefix + i + 'Enabled';
                    data[key] = data[key] === 'true' || data[key] === 'True';
                }
            }

            $('#autoSaveStatus').text('Saving...');
            $.ajax({
                url: '@Url.Action("AutoSave", "Inventory")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    if (res.success) {
                        $('#autoSaveStatus').html('<i class="bi bi-check-circle me-1"></i>Saved at ' + new Date().toLocaleTimeString()).removeClass('text-danger').addClass('text-success');
                    } else {
                        $('#autoSaveStatus').text(res.message).removeClass('text-success').addClass('text-danger');
                    }
                },
                error: function () {
                    $('#autoSaveStatus').html('<i class="bi bi-exclamation-circle me-1"></i>Save failed').addClass('text-danger');
                }
            });
        }, 10000);

        // --- Custom ID Format Editor ---
        const typeLabels = {0:'Fixed Text',1:'Sequence',2:'Date/Time',3:'20-bit Random',4:'32-bit Random',5:'6-Digit Random',6:'9-Digit Random',7:'GUID'};
        const typeIcons = {0:'bi-fonts',1:'bi-sort-numeric-up',2:'bi-calendar',3:'bi-dice-3',4:'bi-dice-5',5:'bi-hash',6:'bi-hash',7:'bi-upc'};
        let idElements = [];

        function renderElements() {
            const $list = $('#idElementsList');
            $list.empty();
            if (idElements.length === 0) {
                $list.html('<p class="text-muted small m-2">No elements. Add elements below to build an ID format.</p>');
                $('#idPreview').text('—');
                return;
            }
            idElements.forEach((el, idx) => {
                const typeInt = el.elementType;
                const showValue = typeInt === 0;
                const showPadding = [1,3,4,5,6,7].includes(typeInt);
                const showDateFmt = typeInt === 2;
                const $card = $(`<div class="border rounded p-2 mb-2 d-flex align-items-center gap-2 id-element" draggable="true" data-idx="${idx}" style="cursor:grab; background:var(--bg-secondary);">
                    <i class="bi ${typeIcons[typeInt]} text-primary"></i>
                    <strong class="small">${typeLabels[typeInt]}</strong>
                    ${showValue ? `<input type="text" class="form-control form-control-sm el-value" value="${el.value || ''}" placeholder="Text..." style="width:120px;">` : ''}
                    ${showPadding ? `<input type="number" class="form-control form-control-sm el-padding" value="${el.paddingLength || ''}" placeholder="Pad" style="width:70px;" min="0" max="32" title="Leading zeros padding length">` : ''}
                    ${showDateFmt ? `<input type="text" class="form-control form-control-sm el-datefmt" value="${el.dateFormat || 'yyyyMMdd'}" placeholder="yyyyMMdd" style="width:140px;" title="C# date format: yyyy=year, MM=month, dd=day, HH=hour, mm=min, ss=sec">` : ''}
                    <button type="button" class="btn btn-sm btn-ghost-danger ms-auto remove-el-btn" title="Remove"><i class="bi bi-x-lg"></i></button>
                </div>`);
                $list.append($card);
            });
            // Bind input changes
            $list.find('.el-value').on('input', function() {
                const idx = $(this).closest('.id-element').data('idx');
                idElements[idx].value = $(this).val();
                updatePreview();
            });
            $list.find('.el-padding').on('input', function() {
                const idx = $(this).closest('.id-element').data('idx');
                idElements[idx].paddingLength = parseInt($(this).val()) || null;
                updatePreview();
            });
            $list.find('.el-datefmt').on('input', function() {
                const idx = $(this).closest('.id-element').data('idx');
                idElements[idx].dateFormat = $(this).val();
                updatePreview();
            });
            $list.find('.remove-el-btn').on('click', function() {
                const idx = $(this).closest('.id-element').data('idx');
                idElements.splice(idx, 1);
                renderElements();
            });
            updatePreview();
            initDragDrop();
        }

        function initDragDrop() {
            let dragIdx = null;
            const $list = $('#idElementsList');
            $list.find('.id-element').on('dragstart', function(e) {
                dragIdx = $(this).data('idx');
                $(this).css('opacity','0.4');
                e.originalEvent.dataTransfer.effectAllowed = 'move';
            });
            $list.find('.id-element').on('dragend', function() {
                $(this).css('opacity','1');
                dragIdx = null;
            });
            $list.find('.id-element').on('dragover', function(e) {
                e.preventDefault();
                e.originalEvent.dataTransfer.dropEffect = 'move';
                $(this).css('border-top', '3px solid var(--primary-color)');
            });
            $list.find('.id-element').on('dragleave', function() {
                $(this).css('border-top', '');
            });
            $list.find('.id-element').on('drop', function(e) {
                e.preventDefault();
                $(this).css('border-top', '');
                const dropIdx = $(this).data('idx');
                if (dragIdx !== null && dragIdx !== dropIdx) {
                    const moved = idElements.splice(dragIdx, 1)[0];
                    idElements.splice(dropIdx, 0, moved);
                    renderElements();
                }
            });
            // Drop outside = remove
            $list.on('dragover', function(e) { e.preventDefault(); });
            $(document).on('drop.customid', function(e) {
                if (dragIdx !== null && !$(e.target).closest('#idElementsList').length) {
                    idElements.splice(dragIdx, 1);
                    dragIdx = null;
                    renderElements();
                }
            });
        }

        function updatePreview() {
            if (idElements.length === 0) { $('#idPreview').text('—'); return; }
            $.ajax({
                url: '/api/custom-id/preview',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ elements: idElements.map((el, i) => ({...el, sortOrder: i})) }),
                success: function(res) { $('#idPreview').text(res.preview || '—'); },
                error: function() { $('#idPreview').text('Error'); }
            });
        }

        // Add element buttons
        $(document).on('click', '.add-element-btn', function() {
            if (idElements.length >= 10) { alert('Maximum 10 elements recommended.'); return; }
            const type = parseInt($(this).data('type'));
            const el = { elementType: type, value: null, paddingLength: null, dateFormat: null, sortOrder: idElements.length };
            if (type === 0) el.value = '';
            if (type === 2) el.dateFormat = 'yyyyMMdd';
            if (type === 7) el.paddingLength = 8;
            if (type === 5) el.paddingLength = 6;
            if (type === 6) el.paddingLength = 9;
            if (type === 3) el.paddingLength = 7;
            if (type === 4) el.paddingLength = 10;
            idElements.push(el);
            renderElements();
        });

        // Save format
        $('#saveFormatBtn').on('click', function() {
            const data = { elements: idElements.map((el, i) => ({...el, sortOrder: i})) };
            $('#formatSaveStatus').text('Saving...').removeClass('text-danger text-success');
            $.ajax({
                url: '/api/inventory/' + inventoryId + '/custom-id-format',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function(res) {
                    $('#formatSaveStatus').text('Saved!').addClass('text-success');
                    if (res && res.elements) {
                        idElements = res.elements.map(e => ({elementType:e.elementType, value:e.value, paddingLength:e.paddingLength, dateFormat:e.dateFormat, sortOrder:e.sortOrder}));
                    }
                },
                error: function() { $('#formatSaveStatus').text('Save failed').addClass('text-danger'); }
            });
        });

        // Clear all
        $('#clearFormatBtn').on('click', function() {
            if (!confirm('Remove all ID elements?')) return;
            idElements = [];
            renderElements();
            $.ajax({ url: '/api/inventory/' + inventoryId + '/custom-id-format', type: 'DELETE' });
        });

        // Load existing format
        $.get('/api/inventory/' + inventoryId + '/custom-id-format', function(data) {
            if (data && data.elements && data.elements.length > 0) {
                idElements = data.elements.map(e => ({elementType:e.elementType, value:e.value, paddingLength:e.paddingLength, dateFormat:e.dateFormat, sortOrder:e.sortOrder}));
            }
            renderElements();
        });

        // Enable Bootstrap popovers
        $('[data-bs-toggle="popover"]').each(function() {
            new bootstrap.Popover(this);
        });
    </script>
}
